apiVersion: 1

datasources:
  - name: PostgreSQL-SellIn
    type: postgres
    access: proxy
    url: postgres:5432
    user: sellin
    secureJsonData:
      password: sellin
    jsonData:
      database: sellin
      sslmode: disable
      postgresVersion: 1500
      timescaledb: false
      connMaxLifetime: 14400
