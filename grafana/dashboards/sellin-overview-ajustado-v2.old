          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT * FROM ( SELECT id_pdv, id_sku, SUM(venda_total) AS venda_total, SUM(quantidade_total) AS quantidade_total, RANK() OVER ( PARTITION BY id_pdv ORDER BY SUM(venda_total) DESC ) AS ranking_sku FROM weekly_pdv_sales GROUP BY id_pdv, id_sku ) t WHERE ranking_sku = 1 ORDER BY venda_total DESC;",
          "refId": "A"
        }
      ],
      "title": "Ranking de SKU mais vendido por PDV",
