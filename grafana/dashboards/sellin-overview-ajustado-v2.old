          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT id_pdv, ROUND(SUM(venda_total), 2) AS total_vendido, SUM(quantidade_total) AS total_quantidade, COUNT(DISTINCT anio_semana) AS semanas_ativas FROM weekly_pdv_sales GROUP BY id_pdv ORDER BY total_vendido DESC LIMIT 20;",
